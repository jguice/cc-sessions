    def on_mount(self):
        tree = self.query_one("#session-tree", Tree)
        tree.show_root = False
        tree.guide_depth = 3
        self._rebuild_tree()
        self._update_status()
        sort_label = "folder name" if self.sort_mode == "name" else self.sort_mode
        self.sub_title = f"sorted by {sort_label}"
        tree.focus()

    def watch_theme(self, new_theme: str) -> None:
        """Rebuild tree when theme changes so colors update, and save preference."""
        try:
            self.query_one("#session-tree", Tree)
            self._rebuild_tree()
        except Exception:
            pass  # tree not mounted yet
        self._save_prefs()

    @staticmethod
    def _load_prefs() -> dict:
        if os.path.exists(PREFS_FILE):
            try:
                with open(PREFS_FILE) as f:
                    return json.load(f)
            except Exception:
                pass
        return {}

    def _save_prefs(self):
        prefs = self._load_prefs()
        prefs["theme"] = self.theme
        os.makedirs(os.path.dirname(PREFS_FILE), exist_ok=True)
        with open(PREFS_FILE, "w") as f:
            json.dump(prefs, f, indent=2)

    # -- Tree building --

    def _rebuild_tree(self):
        tree = self.query_one("#session-tree", Tree)
        tree.clear()

        # Pull colors from the active theme
        theme = self.current_theme
        accent = theme.accent if theme else "#fabd2f"
        primary = theme.primary if theme else "#85A598"
        secondary = theme.secondary if theme else "#A89A85"
        success = theme.success if theme else "#b8bb26"

        filtered = self.sessions
        if self.filter_text:
            ft = self.filter_text.lower()
            filtered = [
                s for s in self.sessions
                if ft in s["first_msg"].lower()
                or ft in s["cwd_short"].lower()
                or ft in s["session_id"].lower()
                or ft in self.session_names.get(s["session_id"], "").lower()
            ]

        groups = group_sessions(filtered, self.sort_mode)

        for _, cwd, items in groups:
            cwd_condensed = condense_path(cwd)
            cwd_short = cwd.replace(HOME, "~")

            # Directory label with folder icon, using theme colors
            dir_text = Text()
            dir_text.append(f"{ICON_FOLDER} ", style=f"bold {accent}")
            dir_text.append(f"{cwd_condensed} ", style=f"bold {primary}")
            dir_text.append(f"({len(items)})", style="dim")
            dir_node = tree.root.add(dir_text, expand=False)
            dir_node.data = None  # directory nodes have no session data

            for s in items:
                age = human_age(s["age"])
                size = human_size(s["size"])
                name = self.session_names.get(s["session_id"], "")

                label = Text()
                if s["session_id"] in self.selected_ids:
                    label.append(f"{ICON_CHECK} ", style=f"bold {success}")
                label.append(f"{ICON_CLOCK} {age:>7} ", style=f"{accent}")
                label.append(f"{ICON_SIZE} {size:>7}", style="dim")
                label.append("  ", style="")
                if name:
                    label.append(f"[{name}] ", style=f"bold {secondary}")
                label.append(s["first_msg"])

                leaf = dir_node.add_leaf(label)
                leaf.data = s

    def _update_status(self):
        total = len(self.sessions)
        selected = len(self.selected_ids)
        sort_label = self.sort_mode.capitalize()
        parts = [f"{ICON_SESSION} {total} sessions", f"{ICON_SORT} {sort_label}"]
        if selected:
            parts.append(f"{selected} selected")
        if self.filter_text:
            parts.append(f"Filter: {self.filter_text}")
        self.query_one("#status-bar", Static).update(" | ".join(parts))

    def _update_preview(self, session: dict | None):
        preview = self.query_one("#preview", Markdown)
        if session is None:
            preview.update("")
            return

        sid = session["session_id"]
        name = self.session_names.get(sid, "")
        size = human_size(session["size"])
        name_line = f"\n**Name:** {name}" if name else ""

        msg = prepare_markdown(session.get("first_msg_raw", ""))

        md = f"""**Session:** {sid}{name_line}
**Directory:** {session['cwd_short']}
**Size:** {size}

---

{msg}
"""
        preview.update(md)

    # -- Event handlers --

    def on_tree_node_selected(self, event: Tree.NodeSelected):
        """When Enter is pressed on a tree node."""
        node = event.node
        if node.data is None:
            # Directory node: toggle expand/collapse
            node.toggle()
        else:
            # Session node: resume it
            self._resume_session = node.data
            self.exit()

    def on_tree_node_highlighted(self, event: Tree.NodeHighlighted):
        """Update preview when cursor moves."""
        node = event.node
        if node.data is not None:
            self._update_preview(node.data)
        else:
            self._update_preview(None)

    # -- Vi navigation --

    def action_scroll_home(self):
        tree = self.query_one("#session-tree", Tree)
        tree.action_scroll_home()

    def action_scroll_end(self):
        tree = self.query_one("#session-tree", Tree)
        tree.action_scroll_end()

    def action_page_up(self):
        tree = self.query_one("#session-tree", Tree)
        tree.scroll_page_up()

    def action_page_down(self):
        tree = self.query_one("#session-tree", Tree)
        tree.scroll_page_down()

    def on_key(self, event):
        """Handle vi keys and left/right arrows for tree navigation."""
        tree = self.query_one("#session-tree", Tree)
        node = tree.cursor_node
        if node is None:
            return

        # h/l map to left/right (expand/collapse), j/k map to down/up
        if event.key in ("left", "h"):
            if node.data is None and node.is_expanded:
                node.collapse()
                event.prevent_default()
            elif node.data is not None:
                if node.parent and node.parent != tree.root:
                    tree.select_node(node.parent)
                    node.parent.collapse()
                    event.prevent_default()
            elif node.data is None and not node.is_expanded:
                # Already collapsed dir: move to parent
                if node.parent and node.parent != tree.root:
                    tree.select_node(node.parent)
                    event.prevent_default()
        elif event.key in ("right", "l"):
            if node.data is None and not node.is_expanded:
                node.expand()
                event.prevent_default()
            elif node.data is None and node.is_expanded:
                # Already expanded: move to first child
                if node.children:
                    tree.select_node(node.children[0])
                    event.prevent_default()
        elif event.key == "j":
            tree.action_cursor_down()
            event.prevent_default()
        elif event.key == "k":
            tree.action_cursor_up()
            event.prevent_default()
        elif event.key == "escape":
            search_bar = self.query_one("#search-bar")
            if search_bar.styles.display != "none":
                self._close_search()
                event.prevent_default()

    # -- Actions --

    def action_search(self):
        search_bar = self.query_one("#search-bar")
        search_input = self.query_one("#search-input", Input)
        if search_bar.styles.display == "none":
            search_bar.styles.display = "block"
            search_input.value = self.filter_text
            search_input.focus()
        else:
            self._close_search()

    def _close_search(self):
        self.query_one("#search-bar").styles.display = "none"
        self.query_one("#session-tree", Tree).focus()

    def on_input_changed(self, event: Input.Changed):
        if event.input.id == "search-input":
            self.filter_text = event.value
            self._rebuild_tree()
            self._update_status()

    def on_input_submitted(self, event: Input.Submitted):
        if event.input.id == "search-input":
            self.query_one("#search-bar").styles.display = "none"
            self.query_one("#session-tree", Tree).focus()

    def action_expand_all(self):
        tree = self.query_one("#session-tree", Tree)
        for node in tree.root.children:
            node.expand()

    def action_collapse_all(self):
        tree = self.query_one("#session-tree", Tree)
        for node in tree.root.children:
            node.collapse()

    def run_palette_command(self, command: str):
        """Execute a command from the command palette."""
        actions = {
            "expand_all": self.action_expand_all,
            "collapse_all": self.action_collapse_all,
            "sort_name": lambda: self._set_sort("name"),
            "sort_recency": lambda: self._set_sort("recency"),
            "sort_size": lambda: self._set_sort("size"),
            "search": self.action_search,
            "clear_search": self._clear_search,
            "archive": self.action_archive,
            "delete": self.action_delete,
            "rename": self.action_rename,
            "toggle_skip_perms": self._toggle_skip_perms,
        }
        if command in actions:
            actions[command]()

    def _set_sort(self, mode: str):
        self.sort_mode = mode
        self._rebuild_tree()
        self._update_status()
        sort_label = "folder name" if self.sort_mode == "name" else self.sort_mode
        self.sub_title = f"sorted by {sort_label}"

    def _toggle_skip_perms(self):
        prefs = self._load_prefs()
        current = prefs.get("dangerously_skip_permissions", False)
        prefs["dangerously_skip_permissions"] = not current
        os.makedirs(os.path.dirname(PREFS_FILE), exist_ok=True)
        with open(PREFS_FILE, "w") as f:
            json.dump(prefs, f, indent=2)
        state = "ON" if not current else "OFF"
        self._update_status()
        self.notify(f"Skip permissions: {state}")

    def _clear_search(self):
        self.filter_text = ""
        self._rebuild_tree()
        self._update_status()

    def action_cycle_sort(self):
        idx = SORT_MODES.index(self.sort_mode)
        self.sort_mode = SORT_MODES[(idx + 1) % len(SORT_MODES)]
        self._rebuild_tree()
        self._update_status()
        sort_label = "folder name" if self.sort_mode == "name" else self.sort_mode
        self.sub_title = f"sorted by {sort_label}"

    def action_toggle_select(self):
        tree = self.query_one("#session-tree", Tree)
        node = tree.cursor_node
        if node and node.data:
            sid = node.data["session_id"]
            if sid in self.selected_ids:
                self.selected_ids.discard(sid)
            else:
                self.selected_ids.add(sid)
            self._rebuild_tree()
            self._update_status()

    def action_delete(self):
        tree = self.query_one("#session-tree", Tree)
        node = tree.cursor_node
        if node and node.data:
            s = node.data
            name = self.session_names.get(s["session_id"], s["session_id"][:12])
            self.push_screen(
                ConfirmDialog(f"Delete session '{name}' permanently?"),
                callback=lambda ok: self._do_delete([s]) if ok else None,
            )

    def action_archive(self):
        tree = self.query_one("#session-tree", Tree)
        node = tree.cursor_node
        if node and node.data:
            s = node.data
            name = self.session_names.get(s["session_id"], s["session_id"][:12])
            self.push_screen(
                ConfirmDialog(f"Archive session '{name}'?"),
                callback=lambda ok: self._do_archive([s]) if ok else None,
            )

    def action_delete_selected(self):
        if not self.selected_ids:
            return
        targets = [s for s in self.sessions if s["session_id"] in self.selected_ids]
        self.push_screen(
            ConfirmDialog(f"Delete {len(targets)} sessions permanently?"),
            callback=lambda ok: self._do_delete(targets) if ok else None,
        )

    def action_archive_selected(self):
        if not self.selected_ids:
            return
        targets = [s for s in self.sessions if s["session_id"] in self.selected_ids]
        self.push_screen(
            ConfirmDialog(f"Archive {len(targets)} sessions?"),
            callback=lambda ok: self._do_archive(targets) if ok else None,
        )

    def action_rename(self):
        tree = self.query_one("#session-tree", Tree)
        node = tree.cursor_node
        if node and node.data:
            sid = node.data["session_id"]
            current = self.session_names.get(sid, "")
            self.push_screen(
                RenameDialog(current),
                callback=lambda name: self._do_rename(sid, name),
            )

    def _do_delete(self, targets: list[dict]):
        for s in targets:
            try:
                os.remove(s["path"])
                # Remove subagents dir too
                subdir = os.path.join(os.path.dirname(s["path"]), "subagents")
                if os.path.isdir(subdir):
                    shutil.rmtree(subdir, ignore_errors=True)
            except Exception:
                pass
            self.selected_ids.discard(s["session_id"])
        self.sessions = [s for s in self.sessions if s not in targets]
        self._rebuild_tree()
        self._update_status()
        self._update_preview(None)

    def _do_archive(self, targets: list[dict]):
        os.makedirs(ARCHIVE_DIR, exist_ok=True)
        for s in targets:
            try:
                dest = os.path.join(ARCHIVE_DIR, os.path.basename(s["path"]))
                shutil.move(s["path"], dest)
                subdir = os.path.join(os.path.dirname(s["path"]), "subagents")
                if os.path.isdir(subdir):
                    shutil.move(subdir, os.path.join(ARCHIVE_DIR, s["session_id"] + "-subagents"))
            except Exception:
                pass
            self.selected_ids.discard(s["session_id"])
        self.sessions = [s for s in self.sessions if s not in targets]
        self._rebuild_tree()
        self._update_status()
        self._update_preview(None)

    def _do_rename(self, session_id: str, name: str):
        if not name:
            self.session_names.pop(session_id, None)
        else:
            self.session_names[session_id] = name
        save_session_names(self.session_names)
        self._rebuild_tree()
        self._update_preview_for_current()

    def _update_preview_for_current(self):
        tree = self.query_one("#session-tree", Tree)
        node = tree.cursor_node
        if node and node.data:
            self._update_preview(node.data)


def main():
    app = SessionBrowser()
    app.run()

    # After the app exits, if a session was selected, print the resume command
    if app._resume_session:
        s = app._resume_session
        prefs = SessionBrowser._load_prefs()
        skip_perms = "1" if prefs.get("dangerously_skip_permissions", False) else "0"
        print(f"RESUME\t{s['cwd']}\t{s['session_id']}\t{skip_perms}")


if __name__ == "__main__":
    main()
