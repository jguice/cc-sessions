def human_size(nbytes: int) -> str:
    for unit in ("B", "KB", "MB", "GB"):
        if nbytes < 1024:
            return f"{nbytes}{unit}" if unit == "B" else f"{nbytes:.1f}{unit}"
        nbytes /= 1024
    return f"{nbytes:.1f}TB"


def human_age(seconds: float) -> str:
    if seconds < 3600:
        return f"{int(seconds / 60)}m ago"
    if seconds < 86400:
        return f"{int(seconds / 3600)}h ago"
    return f"{int(seconds / 86400)}d ago"


def condense_path(path: str) -> str:
    short = path.replace(HOME, "~")
    parts = short.split("/")
    if len(parts) > 2:
        return "/".join([parts[0]] + [p[0] if p else p for p in parts[1:-1]] + [parts[-1]])
    return short


def load_session_names() -> dict:
    if os.path.exists(NAMES_FILE):
        try:
            with open(NAMES_FILE) as f:
                return json.load(f)
        except Exception:
            pass
    return {}


def save_session_names(names: dict):
    os.makedirs(os.path.dirname(NAMES_FILE), exist_ok=True)
    with open(NAMES_FILE, "w") as f:
        json.dump(names, f, indent=2)


def load_sessions():
    """Scan all session files and return a list of session dicts."""
    sessions = []
    for jsonl_path in glob.glob(os.path.join(PROJECTS_BASE, "*", "*.jsonl")):
        if "/subagents/" in jsonl_path:
            continue
        mtime = os.path.getmtime(jsonl_path)
        session_id = os.path.basename(jsonl_path).replace(".jsonl", "")
        fsize = os.path.getsize(jsonl_path)
        cwd = ""
        first_msg = ""
        first_msg_raw = ""
        try:
            with open(jsonl_path) as f:
                for i, line in enumerate(f):
                    if i > 50:
                        break
                    try:
                        d = json.loads(line)
                    except Exception:
                        continue
                    if not cwd and d.get("cwd"):
                        cwd = d["cwd"]
                    if not first_msg and d.get("type") == "user":
                        content = d.get("message", {}).get("content", "")
                        if isinstance(content, list):
                            for c in content:
                                if isinstance(c, dict) and c.get("type") == "text":
                                    text = c["text"].strip()
                                    text = re.sub(r"<[^>]+>", "", text).strip()
                                    if text:
                                        first_msg_raw = text
                                        first_msg = text.replace("\n", " ")
                                        break
                        elif isinstance(content, str):
                            text = re.sub(r"<[^>]+>", "", content).strip()
                            first_msg_raw = text
                            first_msg = text.replace("\n", " ")
                    if cwd and first_msg:
                        break
        except Exception:
            continue
        if cwd:
            sessions.append({
                "mtime": mtime,
                "session_id": session_id,
                "cwd": cwd,
                "cwd_short": cwd.replace(HOME, "~"),
                "cwd_condensed": condense_path(cwd),
                "first_msg": first_msg,
                "first_msg_raw": first_msg_raw,
                "path": jsonl_path,
                "size": fsize,
                "age": time.time() - mtime,
            })
    return sessions


def group_sessions(sessions, sort_mode="recency"):
    """Group sessions by directory and sort."""
    from collections import defaultdict
    groups = defaultdict(list)
    for s in sessions:
        groups[s["cwd"]].append(s)

    for items in groups.values():
        # Sessions within a group always sort by recency first,
        # then by the selected secondary sort
        if sort_mode == "size":
            items.sort(key=lambda x: -x["size"])
        else:
            items.sort(key=lambda x: -x["mtime"])

    sorted_groups = []
    for cwd, items in groups.items():
        sorted_groups.append((items[0]["mtime"], cwd, items))

    # Sort groups: by name sorts directories alphabetically, others by most recent session
    if sort_mode == "name":
        sorted_groups.sort(key=lambda x: condense_path(x[1]).lower())
    else:
        sorted_groups.sort(key=lambda x: -x[0])
    return sorted_groups


def render_table(table_text: str) -> str:
    """Convert a markdown table to aligned plain text with box-drawing chars."""
    lines = [l.strip() for l in table_text.strip().split("\n") if l.strip()]
    if len(lines) < 2:
        return table_text
    rows = []
    for i, l in enumerate(lines):
        if i == 1:
            continue
        cells = [c.strip() for c in l.split("|")[1:-1]]
        rows.append(cells)
    if not rows:
        return table_text
    ncols = max(len(r) for r in rows)
    widths = [0] * ncols
    for r in rows:
        for j, c in enumerate(r):
            if j < ncols:
                widths[j] = max(widths[j], len(c))
    out = []
    sep = "\u2500" + "\u2500\u253c\u2500".join("\u2500" * (w + 1) for w in widths) + "\u2500"
    for i, r in enumerate(rows):
        padded = []
        for j in range(ncols):
            val = r[j] if j < len(r) else ""
            padded.append(val.ljust(widths[j]))
        out.append(" " + " \u2502 ".join(padded))
        if i == 0:
            out.append(sep)
    return "\n".join(out)


def prepare_markdown(msg: str) -> str:
    """Pre-process markdown: convert tables to code blocks for proper rendering."""
    table_pattern = re.compile(r"(\n?\|[^\n]+\|\n\|[\s:|-]+\|\n(?:\|[^\n]+\|\n?)+)")
    return table_pattern.sub(
        lambda m: "\n```\n" + render_table(m.group(0)) + "\n```\n", msg
    )


